{
  "name": "gnap-openapi-reference-kit",
  "version": "0.1.0",
  "description": "Experimental reference toolkit for describing and validating GNAP-secured Open Payments APIs in OpenAPI.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "gnap-openapi": "./dist/cli.js"
  },
  "scripts": {
